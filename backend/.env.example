# Copy to backend/.env and adjust as needed.
# Device for OmniVoice + UTMOS: cuda | mps | cpu (auto-detected if unset)
SOTOSPEAK_DEVICE=mps
# Hugging Face model id or local path
SOTOSPEAK_MODEL=k2-fsa/OmniVoice
# Comma-separated CORS origins for the frontend dev server
SOTOSPEAK_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
