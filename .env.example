# Reference for the backend's environment variables. With Docker Compose these
# are set directly in the `environment:` block of docker-compose.yml; for a bare
# backend run you can export them in your shell. All values are optional.

# Device for OmniVoice + UTMOS inside the container.
#   cpu  – default, works everywhere (slow)
#   cuda – NVIDIA GPU host (also uncomment the gpus/deploy block in docker-compose.yml)
SOTOSPEAK_DEVICE=cpu

# Model id and the exact revision to pull (pinned for reproducible deploys).
SOTOSPEAK_MODEL=k2-fsa/OmniVoice
SOTOSPEAK_MODEL_REVISION=c5fdb5ccb189668d56333f77ba2629f4cd7535f4
